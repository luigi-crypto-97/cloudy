@page "/"

<h1>Dashboard</h1>

<div class="cards">
    <div class="card">
        <h3>Utenti attivi 24h</h3>
        <p>@_activeUsers</p>
    </div>
    <div class="card">
        <h3>Check-in attivi</h3>
        <p>@_checkIns</p>
    </div>
    <div class="card">
        <h3>Intentions attive</h3>
        <p>@_intentions</p>
    </div>
    <div class="card">
        <h3>Report aperti</h3>
        <p>@_openReports</p>
    </div>
</div>

<p>TODO: agganciare API reali, grafici e audit trail.</p>

@code {
    private int _activeUsers = 0;
    private int _checkIns = 0;
    private int _intentions = 0;
    private int _openReports = 0;
}
