@page "/moderation"
@inject IHttpClientFactory HttpClientFactory

<h1>Moderazione</h1>

@if (_isLoading)
{
    <p class="muted">Caricamento coda...</p>
}
else if (_error is not null)
{
    <p class="error">@_error</p>
}
else if (_queue.Count == 0)
{
    <section class="ops-panel">
        <p class="muted">Nessun report aperto. Recensioni, utenti e contenuti segnalati compariranno qui.</p>
    </section>
}
else
{
    <section class="metric-grid">
        <MetricCard Label="Report aperti" Value="@_queue.Count" Accent="coral" />
        <MetricCard Label="Recensioni" Value="@RatingReportsCount" Accent="mint" />
        <MetricCard Label="Utenti" Value="@_queue.Count(x => x.ReportedUserId is not null)" Accent="blue" />
        <MetricCard Label="Locali" Value="@_queue.Count(x => x.ReportedVenueId is not null)" Accent="violet" />
    </section>

    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Safety queue</p>
                <h2>Segnalazioni aperte</h2>
            </div>
            <button class="secondary" @onclick="LoadAsync" disabled="@_isLoading">Aggiorna</button>
        </div>

        <table class="grid ops-table">
            <thead>
                <tr>
                    <th>Motivo</th>
                    <th>Priorità</th>
                    <th>Creato</th>
                    <th>Target</th>
                    <th>Report</th>
                    <th>Azioni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _queue.OrderByDescending(PriorityScore).ThenBy(x => x.CreatedAtUtc))
                {
                    <tr>
                        <td>
                            <strong>@ReasonLabel(item.ReasonCode)</strong><br />
                            <span class="muted">@item.ReasonCode</span>
                        </td>
                        <td><span class="pill @PriorityClass(item)">@PriorityLabel(item)</span></td>
                        <td>@item.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                        <td>@ResolveTarget(item)</td>
                        <td><code>@ShortId(item.ReportId)</code></td>
                        <td>
                            <button disabled="@_isResolving" @onclick="() => ResolveAsync(item.ReportId)">Risolvi</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private readonly List<ModerationQueueItemDto> _queue = new();
    private bool _isLoading = true;
    private bool _isResolving;
    private string? _error;

    private int RatingReportsCount => _queue.Count(x => x.ReasonCode.Contains("rating", StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var queue = await client.GetFromJsonAsync<List<ModerationQueueItemDto>>("api/admin/moderation/queue");
            _queue.Clear();
            _queue.AddRange(queue ?? new List<ModerationQueueItemDto>());
        }
        catch (Exception ex)
        {
            _error = $"Impossibile caricare la coda moderazione: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ResolveAsync(Guid reportId)
    {
        _isResolving = true;
        _error = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsync($"api/admin/moderation/{reportId}/resolve", null);
            response.EnsureSuccessStatusCode();
            _queue.RemoveAll(x => x.ReportId == reportId);
        }
        catch (Exception ex)
        {
            _error = $"Impossibile risolvere il report: {ex.Message}";
        }
        finally
        {
            _isResolving = false;
        }
    }

    private static string ResolveTarget(ModerationQueueItemDto item)
    {
        if (item.ReportedUserId is not null) return $"Utente {item.ReportedUserId}";
        if (item.ReportedVenueId is not null) return $"Venue {item.ReportedVenueId}";
        if (item.ReportedSocialTableId is not null) return $"Tavolo {item.ReportedSocialTableId}";
        return "N/D";
    }

    private static string ReasonLabel(string reasonCode) => reasonCode switch
    {
        "fake_venue_rating" => "Recensione non veritiera",
        "spam" => "Spam",
        "abuse" => "Comportamento abusivo",
        "unsafe" => "Contenuto rischioso",
        _ => "Segnalazione"
    };

    private static int PriorityScore(ModerationQueueItemDto item)
    {
        if (item.ReasonCode.Contains("fake", StringComparison.OrdinalIgnoreCase)) return 90;
        if (item.ReasonCode.Contains("abuse", StringComparison.OrdinalIgnoreCase)) return 80;
        if (item.ReportedUserId is not null) return 70;
        return 50;
    }

    private static string PriorityLabel(ModerationQueueItemDto item) => PriorityScore(item) >= 80 ? "alta" : "normale";
    private static string PriorityClass(ModerationQueueItemDto item) => PriorityScore(item) >= 80 ? "intention" : "";
    private static string ShortId(Guid id) => id.ToString("N")[..8];
}
