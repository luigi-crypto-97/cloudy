@page "/users"
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<h1>Monitor utenti</h1>
<p class="muted">Vista operativa privacy-safe: mostra presenza a livello locale/intenzione, non coordinate GPS grezze.</p>

<div class="toolbar">
    <input placeholder="Cerca nickname, nome o email" @bind="_query" @bind:event="oninput" />
    <button @onclick="LoadAsync" disabled="@_isLoading">@(_isLoading ? "Aggiorno..." : "Aggiorna")</button>
</div>

@if (_error is not null)
{
    <p class="error">@_error</p>
}

<div class="cards">
    <div class="card">
        <h3>Utenti caricati</h3>
        <p>@_users.Count</p>
    </div>
    <div class="card">
        <h3>Live venue</h3>
        <p>@_users.Count(x => x.PresenceState == "checked_in")</p>
    </div>
    <div class="card">
        <h3>Intent tonight</h3>
        <p>@_users.Count(x => x.PresenceState == "intention")</p>
    </div>
    <div class="card">
        <h3>Ghost mode</h3>
        <p>@_users.Count(x => x.IsGhostModeEnabled)</p>
    </div>
</div>

<div class="map-shell">
    <div id="opsUsersMap" class="monitor-map osm-map"></div>
    <div class="map-overlay-note">Utenti su venue/intenzioni · privacy-safe</div>
</div>

@if (!_users.Any(x => x.Latitude is not null && x.Longitude is not null))
{
    <div class="empty-note">
        Nessun utente ha una presenza venue-level o un'intenzione attiva in questo momento.
        Attiva i dati demo da Growth Ops o usa check-in/intenzioni reali per popolare la mappa.
    </div>
}

<table class="grid">
    <thead>
        <tr>
            <th>Utente</th>
            <th>Stato</th>
            <th>Locale</th>
            <th>Amici</th>
            <th>Privacy</th>
            <th>Ultimo segnale</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in _users)
        {
            <tr>
                <td>
                    <strong>@DisplayName(user)</strong><br />
                    <span class="muted">@user.Nickname</span>
                </td>
                <td><span class="pill @user.PresenceState">@PresenceLabel(user.PresenceState)</span></td>
                <td>
                    @if (user.VenueName is not null)
                    {
                        <span>@user.VenueName</span><br />
                        <span class="muted">@user.VenueCategory</span>
                    }
                    else
                    {
                        <span class="muted">Nessuna presenza live</span>
                    }
                </td>
                <td>@user.FriendsCount</td>
                <td>
                    <span>@user.PrivacyLevel</span><br />
                    <span class="muted">presence: @(user.SharePresenceWithFriends ? "on" : "off") · intent: @(user.ShareIntentionsWithFriends ? "on" : "off")</span>
                </td>
                <td>@(user.LastSignalAtUtc?.ToLocalTime().ToString("g") ?? "-")</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private readonly List<AdminUserMonitorDto> _users = new();
    private string? _query;
    private string? _error;
    private bool _isLoading;
    private bool _mapPending;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var path = string.IsNullOrWhiteSpace(_query)
                ? "api/admin/users"
                : $"api/admin/users?q={Uri.EscapeDataString(_query)}";
            var users = await client.GetFromJsonAsync<List<AdminUserMonitorDto>>(path);
            _users.Clear();
            _users.AddRange(users ?? new List<AdminUserMonitorDto>());
            _mapPending = true;
        }
        catch (Exception ex)
        {
            _error = $"Impossibile caricare gli utenti: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_mapPending)
        {
            _mapPending = false;
            await RenderMapAsync();
        }
    }

    private static string DisplayName(AdminUserMonitorDto user) =>
        string.IsNullOrWhiteSpace(user.DisplayName) ? $"@{user.Nickname}" : user.DisplayName!;

    private static string Initial(AdminUserMonitorDto user)
    {
        var source = string.IsNullOrWhiteSpace(user.DisplayName) ? user.Nickname : user.DisplayName!;
        return source.Length == 0 ? "?" : source[..1].ToUpperInvariant();
    }

    private static string PresenceLabel(string state) => state switch
    {
        "checked_in" => "Qui ora",
        "intention" => "In arrivo",
        "ghost" => "Ghost",
        _ => "Idle"
    };

    private async Task RenderMapAsync()
    {
        var markers = _users
            .Where(x => x.Latitude is not null && x.Longitude is not null)
            .Take(200)
            .Select((x, index) =>
            {
                var (lat, lng) = OffsetCoordinate(x.Latitude!.Value, x.Longitude!.Value, index);
                return new MapMarker(
                    "user",
                    DisplayName(x),
                    $"{PresenceLabel(x.PresenceState)} · {x.VenueName ?? "nessun locale"} · {x.PrivacyLevel}",
                    lat,
                    lng,
                    null,
                    Initial(x));
            })
            .ToList();
        await JS.InvokeVoidAsync("cloudyAdminMap.render", "opsUsersMap", markers);
    }

    private static (double Latitude, double Longitude) OffsetCoordinate(double latitude, double longitude, int index)
    {
        var angle = (index % 12) * (Math.PI / 6);
        var radius = 0.00014 + ((index / 12) % 3) * 0.00008;
        return (latitude + Math.Sin(angle) * radius, longitude + Math.Cos(angle) * radius);
    }

    private sealed record MapMarker(
        string Type,
        string Name,
        string Subtitle,
        double Latitude,
        double Longitude,
        int? Energy,
        string? Initial);
}
