@page "/growth"
@inject IHttpClientFactory HttpClientFactory

<section class="ops-hero">
    <div>
        <p class="eyebrow">Growth Ops</p>
        <h1>Growth Control</h1>
        <p class="muted">Un pannello semplice per demo data, utenti test e missioni che finiscono nel feed/gamification.</p>
    </div>
    <div class="ops-actions">
        <button @onclick="LoadAsync" disabled="@_isLoading">@(_isLoading ? "Aggiorno..." : "Aggiorna")</button>
    </div>
</section>

@if (_error is not null)
{
    <p class="error">@_error</p>
}
@if (_notice is not null)
{
    <p class="success">@_notice</p>
}

<section class="ops-panel growth-tabs-panel">
    <div class="segmented">
        <button class="@TabClass("overview")" @onclick='() => _tab = "overview"'>Panoramica</button>
        <button class="@TabClass("adventures")" @onclick='() => _tab = "adventures"'>Avventure</button>
        <button class="@TabClass("editor")" @onclick='() => { NewAdventure(); _tab = "editor"; }'>Crea</button>
    </div>
</section>

@if (_tab == "overview")
{
    <section class="growth-shell">
        <div class="ops-panel">
            <div class="panel-title">
                <div>
                    <p class="eyebrow">Runtime</p>
                    <h2>Controlli rapidi</h2>
                </div>
                @if (_flags is not null)
                {
                    <span class="pill">@(_flags.DemoSignalsEnabled ? "demo feed on" : "demo feed off")</span>
                }
            </div>
            <div class="flag-grid">
                <article class="flag-card">
                    <div>
                        <strong>Dati demo feed</strong>
                        <p>Animano Feed, Party Pulse e Intent Radar quando non ci sono ancora segnali reali.</p>
                    </div>
                    <button class="@(_flags?.DemoSignalsEnabled == true ? "danger" : "")" @onclick="ToggleDemoSignalsAsync">
                        @(_flags?.DemoSignalsEnabled == true ? "Spegni" : "Accendi")
                    </button>
                </article>
                <article class="flag-card">
                    <div>
                        <strong>Utenti di prova</strong>
                        <p>Gestisce gli account seed <code>@@cloudy.dev</code> senza toccare gli utenti reali.</p>
                    </div>
                    <button class="@(_flags?.TestUsersEnabled == true ? "danger" : "")" @onclick="ToggleTestUsersAsync">
                        @(_flags?.TestUsersEnabled == true ? "Disattiva" : "Attiva")
                    </button>
                </article>
            </div>
        </div>

        <div class="ops-panel">
            <div class="panel-title">
                <div>
                    <p class="eyebrow">Stato</p>
                    <h2>Missioni configurate</h2>
                </div>
                <button class="secondary" @onclick='() => _tab = "adventures"'>Gestisci</button>
            </div>
            <div class="growth-summary">
                <div><strong>@_adventures.Count(x => x.IsActive)</strong><span>avventure attive</span></div>
                <div><strong>@_adventures.Sum(x => x.Objectives.Count(o => o.IsActive))</strong><span>obiettivi attivi</span></div>
                <div><strong>@_adventures.Sum(x => x.RewardPoints)</strong><span>punti disponibili</span></div>
            </div>
        </div>
    </section>
}
else if (_tab == "adventures")
{
    <section class="ops-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">Gamification</p>
                <h2>Avventure</h2>
            </div>
            <button @onclick='() => { NewAdventure(); _tab = "editor"; }'>Nuova avventura</button>
        </div>
        <div class="adventure-list-simple">
            @foreach (var adventure in _adventures)
            {
                <article class="adventure-row">
                    <div class="adventure-main">
                        <span class="pill @(adventure.IsActive ? "checked_in" : "")">@(adventure.IsActive ? "attiva" : "spenta")</span>
                        <div>
                            <strong>@adventure.Title</strong>
                            <p>@adventure.Description</p>
                            <small>@adventure.Scope · @adventure.Objectives.Count obiettivi · @adventure.RewardPoints punti</small>
                        </div>
                    </div>
                    <div class="button-row">
                        <button class="secondary" @onclick="() => EditAdventure(adventure)">Modifica</button>
                        <button class="danger" @onclick="() => DeleteAdventureAsync(adventure.Id)">Elimina</button>
                    </div>
                </article>
            }
            @if (!_adventures.Any())
            {
                <p class="muted">Nessuna avventura configurata.</p>
            }
        </div>
    </section>
}
else
{
    <section class="ops-panel editor-panel">
        <div class="panel-title">
            <div>
                <p class="eyebrow">@(_edit.Id is null ? "Crea" : "Modifica")</p>
                <h2>Avventura</h2>
            </div>
            <button class="secondary" @onclick='() => _tab = "adventures"'>Torna alla lista</button>
        </div>

        <div class="editor-grid">
            <label>
                Titolo
                <input @bind="_edit.Title" />
            </label>
            <label>
                Scope
                <select @bind="_edit.Scope">
                    <option value="weekly">Settimanale</option>
                    <option value="city">Città</option>
                    <option value="venue">Locale</option>
                    <option value="social">Sociale</option>
                </select>
            </label>
            <label class="editor-wide">
                Descrizione
                <textarea rows="3" @bind="_edit.Description"></textarea>
            </label>
            <label class="check">
                <input type="checkbox" @bind="_edit.IsActive" />
                Attiva avventura
            </label>
        </div>

        <div class="panel-title compact-title">
            <div>
                <p class="eyebrow">Obiettivi</p>
                <h2>Missioni</h2>
            </div>
            <button class="secondary" @onclick="AddObjective">Aggiungi obiettivo</button>
        </div>

        <div class="objective-editor-list">
            @foreach (var objective in _edit.Objectives)
            {
                <article class="objective-editor-card">
                    <input placeholder="Titolo obiettivo" @bind="objective.Title" />
                    <select @bind="objective.MetricKey">
                        <option value="check_in">Check-in</option>
                        <option value="venue_story">Story locale</option>
                        <option value="verified_rating">Recensione verificata</option>
                        <option value="table_join">Tavolo</option>
                        <option value="flare_relay">Relay flare</option>
                        <option value="invite_friend">Invito amico</option>
                    </select>
                    <input type="number" min="1" max="100" @bind="objective.Target" />
                    <input type="number" min="0" max="10000" @bind="objective.RewardPoints" />
                    <label class="check"><input type="checkbox" @bind="objective.IsActive" /> attivo</label>
                </article>
            }
        </div>

        <div class="button-row save-row">
            <button @onclick="SaveAdventureAsync" disabled="@_isSaving">@(_isSaving ? "Salvo..." : "Salva avventura")</button>
            <button class="secondary" @onclick="NewAdventure">Reset</button>
        </div>
    </section>
}

@code {
    private AdminFeatureFlagsDto? _flags;
    private readonly List<AdminAdventureDto> _adventures = new();
    private AdventureEditModel _edit = new();
    private string? _error;
    private string? _notice;
    private bool _isLoading;
    private bool _isSaving;
    private string _tab = "overview";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("api");
            _flags = await client.GetFromJsonAsync<AdminFeatureFlagsDto>("api/admin/ops/flags");
            var adventures = await client.GetFromJsonAsync<List<AdminAdventureDto>>("api/admin/ops/adventures");
            _adventures.Clear();
            _adventures.AddRange(adventures ?? []);
        }
        catch (Exception ex)
        {
            _error = $"Impossibile caricare Growth Ops: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ToggleDemoSignalsAsync()
    {
        var enabled = !(_flags?.DemoSignalsEnabled ?? false);
        await UpdateFlagsAsync(new AdminFeatureFlagsUpdateRequest(enabled, null), enabled ? "Dati demo attivati." : "Dati demo disattivati.");
    }

    private async Task ToggleTestUsersAsync()
    {
        var enabled = !(_flags?.TestUsersEnabled ?? false);
        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsync($"api/admin/ops/test-users/{enabled.ToString().ToLowerInvariant()}", null);
            response.EnsureSuccessStatusCode();
            _flags = _flags is null ? new AdminFeatureFlagsDto(false, enabled) : _flags with { TestUsersEnabled = enabled };
            _notice = enabled ? "Utenti test attivati." : "Utenti test disattivati.";
        }
        catch (Exception ex)
        {
            _error = $"Impossibile aggiornare utenti test: {ex.Message}";
        }
    }

    private async Task UpdateFlagsAsync(AdminFeatureFlagsUpdateRequest request, string notice)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PutAsJsonAsync("api/admin/ops/flags", request);
            response.EnsureSuccessStatusCode();
            _flags = await response.Content.ReadFromJsonAsync<AdminFeatureFlagsDto>();
            _notice = notice;
        }
        catch (Exception ex)
        {
            _error = $"Impossibile aggiornare i flag: {ex.Message}";
        }
    }

    private void NewAdventure()
    {
        _edit = new AdventureEditModel();
    }

    private void EditAdventure(AdminAdventureDto adventure)
    {
        _edit = AdventureEditModel.FromDto(adventure);
        _tab = "editor";
    }

    private void AddObjective()
    {
        _edit.Objectives.Add(new ObjectiveEditModel());
    }

    private async Task SaveAdventureAsync()
    {
        _isSaving = true;
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("api");
            HttpResponseMessage response = _edit.Id is null
                ? await client.PostAsJsonAsync("api/admin/ops/adventures", _edit.ToRequest())
                : await client.PutAsJsonAsync($"api/admin/ops/adventures/{_edit.Id}", _edit.ToRequest());
            response.EnsureSuccessStatusCode();
            _notice = "Avventura salvata.";
            NewAdventure();
            await LoadAsync();
            _tab = "adventures";
        }
        catch (Exception ex)
        {
            _error = $"Impossibile salvare l'avventura: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteAdventureAsync(Guid adventureId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.DeleteAsync($"api/admin/ops/adventures/{adventureId}");
            response.EnsureSuccessStatusCode();
            _notice = "Avventura eliminata.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Impossibile eliminare l'avventura: {ex.Message}";
        }
    }

    private string TabClass(string tab) => _tab == tab ? "active" : string.Empty;
}
