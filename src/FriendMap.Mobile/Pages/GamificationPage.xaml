<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FriendMap.Mobile.Pages.GamificationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    xmlns:models="clr-namespace:FriendMap.Mobile.Models"
    Shell.NavBarIsVisible="False"
    ios:Page.UseSafeArea="True"
    Title="Badge">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundColor}, Dark={StaticResource PageBackgroundColorDark}}">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Padding="24,16,24,8">
            <VerticalStackLayout Spacing="2">
                <Label Text="Badge"
                       FontSize="{StaticResource FontSizeDisplay}"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextColor}, Dark={StaticResource TextColorDark}}" />
                <Label Text="I tuoi traguardi"
                       FontSize="{StaticResource FontSizeCallout}"
                       TextColor="{StaticResource MutedTextColor}" />
            </VerticalStackLayout>
            <ImageButton Grid.Column="1"
                         Command="{Binding RefreshCommand}"
                         Style="{StaticResource IconButtonStyle}"
                         VerticalOptions="Center">
                <ImageButton.Source>
                    <FontImageSource Glyph="&#x21BB;"
                                     FontFamily="SegoeUI"
                                     Size="20"
                                     Color="{AppThemeBinding Light={StaticResource TextColor}, Dark={StaticResource TextColorDark}}" />
                </ImageButton.Source>
            </ImageButton>
        </Grid>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}"
                     RefreshColor="{StaticResource BrandViolet}">
            <ScrollView Padding="0,0,0,90">
                <VerticalStackLayout Padding="24,8,24,32" Spacing="16">

                    <StackLayout BindableLayout.ItemsSource="{Binding Achievements}"
                                 Spacing="12"
                                 IsVisible="{Binding Achievements.Count, Converter={StaticResource NonZeroConverter}}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:UserAchievement">
                                <Border Style="{StaticResource CardStyle}" Padding="14">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border WidthRequest="52"
                                                HeightRequest="52"
                                                StrokeThickness="0"
                                                Background="{StaticResource BrandGradient}"
                                                StrokeShape="RoundRectangle 16">
                                            <Label Text="&#x1F3C6;"
                                                   FontSize="24"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Padding="12,0,0,0" Spacing="2">
                                            <Label Text="{Binding BadgeCode}"
                                                   FontSize="{StaticResource FontSizeCallout}"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextColor}, Dark={StaticResource TextColorDark}}" />
                                            <Label Text="{Binding EarnedAtUtc, StringFormat='Conquistato il {0:dd MMM yyyy}'}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   TextColor="{StaticResource MutedTextColor}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>

                    <VerticalStackLayout Spacing="16"
                                         IsVisible="{Binding ShowEmptyState}"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Margin="0,60">
                        <Border WidthRequest="120"
                                HeightRequest="120"
                                StrokeThickness="0"
                                Background="{StaticResource BrandGradient}"
                                StrokeShape="RoundRectangle 36">
                            <Label Text="&#x1F3C6;"
                                   FontSize="56"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <Label Text="Nessun badge"
                               FontSize="{StaticResource FontSizeTitle2}"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Inizia a usare l'app per sbloccare i primi traguardi!"
                               FontSize="{StaticResource FontSizeCallout}"
                               TextColor="{StaticResource MutedTextColor}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
