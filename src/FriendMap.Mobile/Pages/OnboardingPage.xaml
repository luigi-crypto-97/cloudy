<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FriendMap.Mobile.Pages.OnboardingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    ios:Page.UseSafeArea="True"
    BackgroundColor="#0B0F19">

    <ScrollView>
        <VerticalStackLayout Padding="24,28,24,32"
                             Spacing="18">
            <Border Padding="22"
                    Background="{StaticResource BrandGradient}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Cloudy"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Prima di entrare"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Ti chiediamo solo i permessi che rendono davvero utile l'app: mappa live, inviti e contatti già dentro Cloudy."
                           FontSize="15"
                           TextColor="#E2E8F0" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#1E293B"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="⌖ Posizione"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Guarda dove sta succedendo qualcosa. La posizione serve per centrare la mappa, trovare i locali vicini e mostrarti il live vero intorno a te."
                           FontSize="14"
                           TextColor="#94A3B8" />
                    <Label Text="{Binding LocationStatusText}"
                           FontSize="13"
                           TextColor="#C4B5FD" />
                    <Button Text="Attiva posizione"
                            Clicked="OnActivateLocationClicked"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#1E293B"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="◉ Notifiche"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Non perderti un invito a un tavolo, un messaggio o un flare lanciato dagli amici mentre sei in giro."
                           FontSize="14"
                           TextColor="#94A3B8" />
                    <Label Text="{Binding PushStatusText}"
                           FontSize="13"
                           TextColor="#C4B5FD" />
                    <Button Text="Attiva notifiche"
                            Clicked="OnActivatePushClicked"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="18"
                    BackgroundColor="#111827"
                    Stroke="#1E293B"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="✦ Rubrica"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Serve per preparare la sincronizzazione contatti e accelerare il vero loop social: trovare subito chi dei tuoi contatti è già dentro Cloudy."
                           FontSize="14"
                           TextColor="#94A3B8" />
                    <Label Text="{Binding ContactsStatusText}"
                           FontSize="13"
                           TextColor="#C4B5FD" />
                    <Button Text="Attiva rubrica"
                            Clicked="OnActivateContactsClicked"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Apri impostazioni iPhone"
                    Clicked="OnOpenSettingsClicked"
                    BackgroundColor="#111827"
                    BorderColor="#334155"
                    BorderWidth="1"
                    TextColor="White"
                    CornerRadius="18"
                    HeightRequest="52" />

            <Button Text="{Binding ContinueButtonText}"
                    Clicked="OnContinueClicked"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="18"
                    HeightRequest="56"
                    FontAttributes="Bold" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
