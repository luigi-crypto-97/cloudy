<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FriendMap.Mobile.Pages.MainMapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    ios:Page.UseSafeArea="True"
    Title="Mappa">

    <Grid>
        <maps:Map x:Name="NativeMap"
                  IsShowingUser="True"
                  MapType="Street" />

        <BoxView BackgroundColor="#33EEF4FF" InputTransparent="True" />

        <AbsoluteLayout x:Name="BubbleLayer"
                        CascadeInputTransparent="False"
                        InputTransparent="True" />

        <VerticalStackLayout Margin="16,10,16,0"
                             Spacing="12"
                             VerticalOptions="Start">
            <Border HorizontalOptions="Center"
                    Padding="14,6"
                    BackgroundColor="#243CFF"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#220F172A" Offset="0,8" Radius="20" Opacity="0.22" />
                </Border.Shadow>
                <Label Text="FriendMap"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="White" />
            </Border>

            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <Border Padding="16,13"
                        BackgroundColor="#EAF7FFFF"
                        Stroke="#DDE7F5"
                        StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#180F172A" Offset="0,10" Radius="26" Opacity="0.18" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Live ora"
                               FontSize="11"
                               TextColor="{StaticResource MutedTextColor}" />
                        <Label Text="{Binding MapSummaryLabel}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}" />
                    </VerticalStackLayout>
                </Border>

                <Button Grid.Column="1"
                        Text="Server"
                        Clicked="OnServerClicked"
                        MinimumHeightRequest="48"
                        Padding="14,10"
                        FontSize="13"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalOptions="Center" />

                <Button Grid.Column="2"
                        Text="Aggiorna"
                        Clicked="OnRefreshClicked"
                        MinimumHeightRequest="48"
                        Padding="16,10"
                        FontSize="13"
                        Style="{StaticResource PrimaryButtonStyle}"
                        VerticalOptions="Center" />
            </Grid>

            <Border Padding="12,9"
                    BackgroundColor="#FDFEFF"
                    Stroke="#E3EBF5"
                    StrokeThickness="1"
                    IsVisible="{Binding HasStatusMessage}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#120F172A" Offset="0,8" Radius="18" Opacity="0.14" />
                </Border.Shadow>
                <Label Text="{Binding StatusMessage}"
                       FontSize="12"
                       TextColor="{Binding StatusColor}" />
            </Border>

            <Border Padding="14,12"
                    BackgroundColor="#FDFEFF"
                    Stroke="#E3EBF5"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Border Padding="12,4"
                            BackgroundColor="#F8FBFF"
                            Stroke="#E3EBF5"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <Entry x:Name="DiscoverySearchEntry"
                               Placeholder="Cerca locali, zone, categorie"
                               TextChanged="OnDiscoverySearchChanged"
                               ReturnType="Search"
                               BackgroundColor="Transparent"
                               TextColor="{StaticResource TextColor}"
                               PlaceholderColor="{StaticResource MutedTextColor}" />
                    </Border>

                    <ScrollView Orientation="Horizontal">
                        <HorizontalStackLayout Spacing="8">
                            <Button x:Name="FilterAllButton"
                                    Text="Tutti"
                                    Clicked="OnCategoryAllClicked"
                                    MinimumHeightRequest="34"
                                    Padding="12,8"
                                    FontSize="12"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button x:Name="FilterBarsButton"
                                    Text="Bar"
                                    Clicked="OnCategoryBarsClicked"
                                    MinimumHeightRequest="34"
                                    Padding="12,8"
                                    FontSize="12"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="FilterFoodButton"
                                    Text="Food"
                                    Clicked="OnCategoryFoodClicked"
                                    MinimumHeightRequest="34"
                                    Padding="12,8"
                                    FontSize="12"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="FilterOpenNowButton"
                                    Text="Open now"
                                    Clicked="OnOpenNowToggleClicked"
                                    MinimumHeightRequest="34"
                                    Padding="12,8"
                                    FontSize="12"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button x:Name="FilterDistanceButton"
                                    Text="Ovunque"
                                    Clicked="OnDistanceFilterClicked"
                                    MinimumHeightRequest="34"
                                    Padding="12,8"
                                    FontSize="12"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <HorizontalStackLayout Margin="18,0,18,126"
                               HorizontalOptions="Fill"
                               VerticalOptions="End"
                               Spacing="10"
                               InputTransparent="False">
            <VerticalStackLayout Spacing="6"
                                 HorizontalOptions="Start">
                <ImageButton Source="icon-location-blue.svg"
                             WidthRequest="52"
                             HeightRequest="52"
                             MinimumHeightRequest="52"
                             Padding="14"
                             Clicked="OnFocusMarkersClicked"
                             BackgroundColor="#F8FBFF"
                             BorderWidth="0"
                             CornerRadius="26">
                    <ImageButton.Shadow>
                        <Shadow Brush="#180F172A" Offset="0,10" Radius="22" Opacity="0.18" />
                    </ImageButton.Shadow>
                </ImageButton>
                <Label Text="Locali"
                       FontSize="11"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource MutedTextColor}" />
            </VerticalStackLayout>

            <Grid HorizontalOptions="FillAndExpand" />

            <VerticalStackLayout Spacing="6"
                                 HorizontalOptions="End">
                <ImageButton Source="icon-focus-blue.svg"
                             WidthRequest="52"
                             HeightRequest="52"
                             MinimumHeightRequest="52"
                             Padding="14"
                             Clicked="OnCenterUserLocationClicked"
                             BackgroundColor="#F8FBFF"
                             BorderWidth="0"
                             CornerRadius="26">
                    <ImageButton.Shadow>
                        <Shadow Brush="#180F172A" Offset="0,10" Radius="22" Opacity="0.18" />
                    </ImageButton.Shadow>
                </ImageButton>
                <Label Text="Posizione"
                       FontSize="11"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource MutedTextColor}" />
            </VerticalStackLayout>
        </HorizontalStackLayout>

        <Border Padding="18"
                Margin="28"
                BackgroundColor="#FDFEFF"
                Stroke="#D7E3F1"
                StrokeThickness="1"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsVisible="{Binding ShowEmptyState}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#160F172A" Offset="0,12" Radius="26" Opacity="0.16" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="8">
                <Label Text="La mappa è pronta"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource TextColor}" />
                <Label Text="Inserisci un backend raggiungibile oppure aggiorna quando l'API è online."
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource MutedTextColor}" />
            </VerticalStackLayout>
        </Border>

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource PrimaryColor}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

        <Border x:Name="VenueSheet"
                Margin="14,0,14,112"
                Padding="14"
                VerticalOptions="End"
                BackgroundColor="#FDFEFF"
                Stroke="#D7E3F1"
                StrokeThickness="1"
                IsVisible="False"
                TranslationY="360">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#1A0F172A" Offset="0,16" Radius="30" Opacity="0.18" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnVenueSheetPanUpdated" />
            </Border.GestureRecognizers>
            <VerticalStackLayout Spacing="12">
                <Border WidthRequest="42"
                        HeightRequest="4"
                        HorizontalOptions="Center"
                        BackgroundColor="#D4DEEB"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="2" />
                    </Border.StrokeShape>
                </Border>

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding SelectedMarker.Name}"
                               FontSize="18"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                               TextColor="{StaticResource TextColor}" />
                        <Label Text="{Binding SelectedMarker.Category}"
                               FontSize="12"
                               TextColor="{StaticResource MutedTextColor}" />
                    </VerticalStackLayout>

                    <Border Grid.Column="1"
                            WidthRequest="48"
                            HeightRequest="48"
                            BackgroundColor="{StaticResource PrimaryColor}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24" />
                        </Border.StrokeShape>
                        <Label Text="{Binding SelectedMarker.PeopleEstimate}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>

                    <ImageButton Grid.Column="2"
                                 Source="icon-close-blue.svg"
                                 WidthRequest="34"
                                 HeightRequest="34"
                                 MinimumHeightRequest="34"
                                 Padding="9"
                                 Command="{Binding DismissSelectionCommand}"
                                 BackgroundColor="#EEF2F7"
                                 BorderWidth="0"
                                 CornerRadius="17" />
                </Grid>

                <HorizontalStackLayout Spacing="8">
                    <Border Padding="10,7"
                            BackgroundColor="#EDF4FF"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="{Binding SelectedPeopleLabel}"
                               FontSize="12"
                               TextColor="{StaticResource PrimaryColorDark}" />
                    </Border>

                    <Border Padding="10,7"
                            BackgroundColor="#F3F7FB"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="{Binding SelectedDensityLabel}"
                               FontSize="12"
                               TextColor="{StaticResource MutedTextColor}" />
                    </Border>
                    <Border Padding="10,7"
                            BackgroundColor="#F6F9FD"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="{Binding SelectedOpenNowLabel}"
                               FontSize="12"
                               TextColor="{StaticResource MutedTextColor}" />
                    </Border>
                </HorizontalStackLayout>

                <Label Text="{Binding SelectedAddressLabel}"
                       FontSize="12"
                       TextColor="{StaticResource MutedTextColor}" />

                <HorizontalStackLayout Spacing="8">
                    <Border Padding="10,7"
                            BackgroundColor="#EEF8FF"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="{Binding SelectedCheckInLabel}"
                               FontSize="11"
                               TextColor="{StaticResource PrimaryColorDark}" />
                    </Border>
                    <Border Padding="10,7"
                            BackgroundColor="#F6F9FD"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="{Binding SelectedIntentionLabel}"
                               FontSize="11"
                               TextColor="{StaticResource MutedTextColor}" />
                    </Border>
                    <Border Padding="10,7"
                            BackgroundColor="#F6F9FD"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="{Binding SelectedTableLabel}"
                               FontSize="11"
                               TextColor="{StaticResource MutedTextColor}" />
                    </Border>
                </HorizontalStackLayout>

                <VerticalStackLayout Spacing="6"
                                     IsVisible="{Binding HasSelectedPresencePreview}">
                    <Label Text="Presenze con te"
                           FontSize="11"
                           TextColor="{StaticResource MutedTextColor}" />
                    <HorizontalStackLayout x:Name="SheetPresenceStack"
                                           Spacing="-8">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSheetPresenceTapped" />
                        </HorizontalStackLayout.GestureRecognizers>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Button Text="Check-in"
                            Command="{Binding CheckInCommand}"
                            IsEnabled="{Binding AreVenueActionsEnabled}"
                            MinimumHeightRequest="42"
                            Padding="10,10"
                            FontSize="13"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Grid.Column="1"
                            Text="Ci vado"
                            Command="{Binding PlanIntentionCommand}"
                            IsEnabled="{Binding AreVenueActionsEnabled}"
                            MinimumHeightRequest="42"
                            Padding="10,10"
                            FontSize="13"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Grid.Column="2"
                            Text="Tavolo"
                            Command="{Binding CreateTableCommand}"
                            IsEnabled="{Binding AreVenueActionsEnabled}"
                            MinimumHeightRequest="42"
                            Padding="10,10"
                            FontSize="13"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>

                <Button Text="Apri scheda locale"
                        Clicked="OnOpenVenueDetailsClicked"
                        MinimumHeightRequest="40"
                        Padding="10,10"
                        FontSize="13"
                        Style="{StaticResource SecondaryButtonStyle}" />

                <Label Text="{Binding ActionMessage}"
                       FontSize="12"
                       TextColor="{StaticResource PrimaryColorDark}"
                       IsVisible="{Binding HasActionMessage}" />
            </VerticalStackLayout>
        </Border>

        <Grid x:Name="VenueDetailOverlay"
              IsVisible="False"
              InputTransparent="False">
            <BoxView BackgroundColor="#260F172A">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVenueDetailOverlayBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border x:Name="VenueDetailSheet"
                    Margin="14,0,14,88"
                    Padding="0"
                    VerticalOptions="End"
                    BackgroundColor="#FCFEFF"
                    Stroke="#DDE7F5"
                    StrokeThickness="1"
                    TranslationY="540">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="32" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1A0F172A" Offset="0,14" Radius="30" Opacity="0.18" />
                </Border.Shadow>
                <Grid RowDefinitions="220,Auto">
                    <Grid HeightRequest="220"
                          BackgroundColor="#E9F2FF"
                          IsClippedToBounds="True">
                        <Image x:Name="VenueDetailCoverImage"
                               Aspect="AspectFill"
                               Opacity="0.92" />
                        <BoxView BackgroundColor="#5E0F172A" />
                        <Grid Padding="16,16,16,18"
                              RowDefinitions="Auto,*,Auto">
                            <Grid ColumnDefinitions="*,Auto">
                                <Border Padding="10,6"
                                        BackgroundColor="#F4F8FF33"
                                        StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>
                                    <Label x:Name="VenueDetailCategoryPillLabel"
                                           Text="Locale"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                </Border>

                                <ImageButton Grid.Column="1"
                                             Source="icon-close-blue.svg"
                                             WidthRequest="34"
                                             HeightRequest="34"
                                             MinimumHeightRequest="34"
                                             Padding="9"
                                             Clicked="OnVenueDetailOverlayCloseClicked"
                                             BackgroundColor="#F8FBFF"
                                             BorderWidth="0"
                                             CornerRadius="17" />
                            </Grid>

                            <VerticalStackLayout Grid.Row="2"
                                                 Spacing="4">
                                <Label x:Name="VenueDetailNameLabel"
                                       Text="Venue"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label x:Name="VenueDetailAddressLabel"
                                       Text="Indirizzo"
                                       FontSize="13"
                                       TextColor="#F8FAFC" />
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>

                    <ScrollView Grid.Row="1"
                                MaximumHeightRequest="480">
                        <VerticalStackLayout Padding="16,16,16,18"
                                             Spacing="14">
                            <Label x:Name="VenueDetailDescriptionLabel"
                                   Text=""
                                   FontSize="14"
                                   TextColor="{StaticResource TextColor}"
                                   IsVisible="False" />

                            <FlexLayout x:Name="VenueDetailTagsLayout"
                                        Wrap="Wrap"
                                        Direction="Row"
                                        JustifyContent="Start"
                                        AlignItems="Start"
                                        IsVisible="False" />

                            <Grid ColumnDefinitions="*,*,*"
                                  ColumnSpacing="8">
                                <Border Padding="12,10"
                                        BackgroundColor="#EEF8FF"
                                        StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Persone"
                                               FontSize="11"
                                               TextColor="{StaticResource MutedTextColor}" />
                                        <Label x:Name="VenueDetailPeopleLabel"
                                               Text="0"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextColor}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="1"
                                        Padding="12,10"
                                        BackgroundColor="#F6F9FD"
                                        StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Affluenza"
                                               FontSize="11"
                                               TextColor="{StaticResource MutedTextColor}" />
                                        <Label x:Name="VenueDetailDensityLabel"
                                               Text="bassa"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextColor}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="2"
                                        Padding="12,10"
                                        BackgroundColor="#F6F9FD"
                                        StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Tavoli"
                                               FontSize="11"
                                               TextColor="{StaticResource MutedTextColor}" />
                                        <Label x:Name="VenueDetailTablesLabel"
                                               Text="0"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextColor}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <VerticalStackLayout Spacing="8">
                                <Label x:Name="VenueDetailHoursLabel"
                                       Text=""
                                       FontSize="13"
                                       TextColor="{StaticResource MutedTextColor}"
                                       IsVisible="False" />
                                <Label x:Name="VenueDetailPhoneLabel"
                                       Text=""
                                       FontSize="13"
                                       TextColor="{StaticResource MutedTextColor}"
                                       IsVisible="False" />
                                <Label x:Name="VenueDetailWebsiteLabel"
                                       Text=""
                                       FontSize="13"
                                       TextColor="{StaticResource MutedTextColor}"
                                       IsVisible="False" />
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="*,*,*"
                                  ColumnSpacing="8">
                                <Button Text="Check-in"
                                        Command="{Binding CheckInCommand}"
                                        MinimumHeightRequest="42"
                                        Padding="10,10"
                                        FontSize="13"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Grid.Column="1"
                                        Text="Ci vado"
                                        Command="{Binding PlanIntentionCommand}"
                                        MinimumHeightRequest="42"
                                        Padding="10,10"
                                        FontSize="13"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Grid.Column="2"
                                        Text="Tavolo"
                                        Command="{Binding CreateTableCommand}"
                                        MinimumHeightRequest="42"
                                        Padding="10,10"
                                        FontSize="13"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <Button Text="Chiama"
                                        Clicked="OnSelectedVenueCallClicked"
                                        MinimumHeightRequest="40"
                                        Padding="10,10"
                                        FontSize="13"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsVisible="{Binding HasSelectedPhone}" />
                                <Button Grid.Column="1"
                                        Text="Sito"
                                        Clicked="OnSelectedVenueWebsiteClicked"
                                        MinimumHeightRequest="40"
                                        Padding="10,10"
                                        FontSize="13"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsVisible="{Binding HasSelectedWebsite}" />
                            </Grid>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="AreaSelectionCard"
                Margin="16,0,16,116"
                Padding="14"
                VerticalOptions="End"
                BackgroundColor="#FCFEFF"
                Stroke="#DDE7F5"
                StrokeThickness="1"
                IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="26" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#170F172A" Offset="0,12" Radius="26" Opacity="0.16" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Spacing="2">
                        <Label x:Name="AreaSelectionTitleLabel"
                               Text="Area"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}" />
                        <Label x:Name="AreaSelectionMetaLabel"
                               Text="0 persone • 0 luoghi"
                               FontSize="12"
                               TextColor="{StaticResource MutedTextColor}" />
                    </VerticalStackLayout>

                    <ImageButton Grid.Column="1"
                                 Source="icon-close-blue.svg"
                                 WidthRequest="34"
                                 HeightRequest="34"
                                 MinimumHeightRequest="34"
                                 Padding="9"
                                 Clicked="OnAreaDismissClicked"
                                 BackgroundColor="#EEF2F7"
                                 BorderWidth="0"
                                 CornerRadius="17" />
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Text="Persone"
                            Clicked="OnAreaPeopleClicked"
                            MinimumHeightRequest="42"
                            Padding="10,10"
                            FontSize="13"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Grid.Column="1"
                            Text="Esplora"
                            Clicked="OnAreaExploreClicked"
                            MinimumHeightRequest="42"
                            Padding="10,10"
                            FontSize="13"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Grid x:Name="PresenceOverlay"
              IsVisible="False"
              InputTransparent="False">
            <BoxView BackgroundColor="#220F172A">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPresenceOverlayBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border x:Name="PresenceSheet"
                    Margin="16,0,16,110"
                    Padding="16"
                    VerticalOptions="End"
                    BackgroundColor="#FCFEFF"
                    Stroke="#DDE7F5"
                    StrokeThickness="1"
                    TranslationY="420">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1A0F172A" Offset="0,14" Radius="30" Opacity="0.18" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label x:Name="PresenceTitleLabel"
                                   Text="Presenti ora"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextColor}" />
                            <Label x:Name="PresenceSubtitleLabel"
                                   Text="Persone visibili in questa zona"
                                   FontSize="12"
                                   TextColor="{StaticResource MutedTextColor}" />
                        </VerticalStackLayout>

                        <ImageButton Grid.Column="1"
                                     Source="icon-close-blue.svg"
                                     WidthRequest="34"
                                     HeightRequest="34"
                                     MinimumHeightRequest="34"
                                     Padding="9"
                                     Clicked="OnPresenceOverlayCloseClicked"
                                     BackgroundColor="#EEF2F7"
                                     BorderWidth="0"
                                     CornerRadius="17" />
                    </Grid>

                    <ScrollView MaximumHeightRequest="260">
                        <VerticalStackLayout x:Name="PresenceListStack"
                                             Spacing="10" />
                    </ScrollView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="ProfileOverlay"
              IsVisible="False"
              InputTransparent="False">
            <BoxView BackgroundColor="#240F172A">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnProfileOverlayBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border x:Name="ProfileSheet"
                    Margin="16,0,16,102"
                    Padding="16"
                    VerticalOptions="End"
                    BackgroundColor="#FCFEFF"
                    Stroke="#DDE7F5"
                    StrokeThickness="1"
                    TranslationY="460">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1A0F172A" Offset="0,14" Radius="30" Opacity="0.18" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Grid x:Name="ProfileAvatarHost"
                              WidthRequest="72"
                              HeightRequest="72" />

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2"
                                             VerticalOptions="Center">
                            <Label x:Name="ProfileNameLabel"
                                   Text="Profilo"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextColor}" />
                            <Label x:Name="ProfileHandleLabel"
                                   Text="@friend"
                                   FontSize="13"
                                   TextColor="{StaticResource MutedTextColor}" />
                        </VerticalStackLayout>

                        <ImageButton Grid.Column="2"
                                     Source="icon-close-blue.svg"
                                     WidthRequest="34"
                                     HeightRequest="34"
                                     MinimumHeightRequest="34"
                                     Padding="9"
                                     Clicked="OnProfileOverlayCloseClicked"
                                     BackgroundColor="#EEF2F7"
                                     BorderWidth="0"
                                     CornerRadius="17" />
                    </Grid>

                    <Label x:Name="ProfileStatusLabel"
                           Text="Nessuna presenza live"
                           FontSize="14"
                           TextColor="{StaticResource TextColor}" />

                    <HorizontalStackLayout Spacing="8">
                        <Border Padding="10,7"
                                BackgroundColor="#EDF4FF"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Label x:Name="ProfileRelationChipLabel"
                                   Text="Non amico"
                                   FontSize="12"
                                   TextColor="{StaticResource PrimaryColorDark}" />
                        </Border>

                        <Border Padding="10,7"
                                BackgroundColor="#F6F9FD"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Label x:Name="ProfileFriendsChipLabel"
                                   Text="0 amici"
                                   FontSize="12"
                                   TextColor="{StaticResource MutedTextColor}" />
                        </Border>

                        <Border Padding="10,7"
                                BackgroundColor="#F6F9FD"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Label x:Name="ProfileMetaChipLabel"
                                   Text="--"
                                   FontSize="12"
                                   TextColor="{StaticResource MutedTextColor}" />
                        </Border>
                    </HorizontalStackLayout>

                    <Border Padding="12,10"
                            BackgroundColor="#F8FBFF"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Venue attuale"
                                   FontSize="11"
                                   TextColor="{StaticResource MutedTextColor}" />
                            <Label x:Name="ProfileVenueLabel"
                                   Text="Nessuna venue live"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextColor}" />
                        </VerticalStackLayout>
                    </Border>

                    <Label x:Name="ProfileBioLabel"
                           Text=""
                           FontSize="13"
                           TextColor="{StaticResource MutedTextColor}"
                           IsVisible="False" />

                    <Label x:Name="ProfileInterestsLabel"
                           Text=""
                           FontSize="12"
                           TextColor="{StaticResource PrimaryColorDark}"
                           IsVisible="False" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8">
                        <Button x:Name="ProfilePrimaryActionButton"
                                Text="Aggiungi"
                                Clicked="OnProfilePrimaryActionClicked"
                                MinimumHeightRequest="42"
                                Padding="10,10"
                                FontSize="13"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button x:Name="ProfileInviteActionButton"
                                Grid.Column="1"
                                Text="Invita al tavolo"
                                Clicked="OnProfileInviteClicked"
                                MinimumHeightRequest="42"
                                Padding="10,10"
                                FontSize="13"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8">
                        <Button x:Name="ProfileMessageActionButton"
                                Text="Chat"
                                Clicked="OnProfileMessageClicked"
                                MinimumHeightRequest="42"
                                Padding="10,10"
                                FontSize="13"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button x:Name="ProfileBlockActionButton"
                                Grid.Column="1"
                                Text="Blocca"
                                Clicked="OnProfileBlockClicked"
                                MinimumHeightRequest="42"
                                Padding="10,10"
                                FontSize="13"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </Grid>

                    <Button x:Name="ProfileReportActionButton"
                            Text="Segnala"
                            Clicked="OnProfileReportClicked"
                            MinimumHeightRequest="40"
                            Padding="10,10"
                            FontSize="13"
                            Style="{StaticResource SecondaryButtonStyle}" />

                    <Label x:Name="ProfileActionMessageLabel"
                           Text=""
                           FontSize="12"
                           TextColor="{StaticResource PrimaryColorDark}"
                           IsVisible="False" />

                    <ActivityIndicator x:Name="ProfileLoadingIndicator"
                                       IsVisible="False"
                                       IsRunning="False"
                                       Color="{StaticResource PrimaryColor}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="SocialOverlay"
              IsVisible="False"
              InputTransparent="False">
            <BoxView BackgroundColor="#240F172A">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSocialOverlayBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border x:Name="SocialSheet"
                    Margin="16,0,16,94"
                    Padding="16"
                    VerticalOptions="End"
                    BackgroundColor="#FCFEFF"
                    Stroke="#DDE7F5"
                    StrokeThickness="1"
                    TranslationY="480">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1A0F172A" Offset="0,14" Radius="30" Opacity="0.18" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Social"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextColor}" />
                            <Label x:Name="SocialSummaryLabel"
                                   Text="Amici e inviti"
                                   FontSize="12"
                                   TextColor="{StaticResource MutedTextColor}" />
                        </VerticalStackLayout>

                        <ImageButton Grid.Column="1"
                                     Source="icon-close-blue.svg"
                                     WidthRequest="34"
                                     HeightRequest="34"
                                     MinimumHeightRequest="34"
                                     Padding="9"
                                     Clicked="OnSocialOverlayCloseClicked"
                                     BackgroundColor="#EEF2F7"
                                     BorderWidth="0"
                                     CornerRadius="17" />
                    </Grid>

                    <ActivityIndicator x:Name="SocialLoadingIndicator"
                                       IsVisible="False"
                                       IsRunning="False"
                                       Color="{StaticResource PrimaryColor}" />

                    <Label x:Name="SocialStatusLabel"
                           Text=""
                           FontSize="12"
                           TextColor="{StaticResource PrimaryColorDark}"
                           IsVisible="False" />

                    <ScrollView MaximumHeightRequest="420">
                        <VerticalStackLayout Spacing="16">
                            <Border Padding="12"
                                    BackgroundColor="#F8FBFF"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="10">
                                    <Label x:Name="SocialPresenceStateLabel"
                                           Text="Nessuna presenza live"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextColor}" />
                                    <Button x:Name="ExitCheckInButton"
                                            Text="Esci ora"
                                            Clicked="OnExitCheckInClicked"
                                            MinimumHeightRequest="40"
                                            Padding="10,10"
                                            FontSize="13"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            IsVisible="False" />
                                    <Button x:Name="OpenEditProfileButton"
                                            Text="Modifica profilo"
                                            Clicked="OnOpenEditProfileClicked"
                                            MinimumHeightRequest="40"
                                            Padding="10,10"
                                            FontSize="13"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                                        <Label Text="Ghost mode"
                                               FontSize="12"
                                               TextColor="{StaticResource TextColor}" />
                                        <Switch x:Name="GhostModeSwitch"
                                                Grid.Column="1"
                                                Toggled="OnGhostModeToggled" />
                                        <Label Grid.Row="1"
                                               Text="Presenza visibile agli amici"
                                               FontSize="12"
                                               TextColor="{StaticResource TextColor}" />
                                        <Switch x:Name="SharePresenceSwitch"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Toggled="OnSharePresenceToggled" />
                                        <Label Grid.Row="2"
                                               Text="Intenzioni visibili agli amici"
                                               FontSize="12"
                                               TextColor="{StaticResource TextColor}" />
                                        <Switch x:Name="ShareIntentionsSwitch"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Toggled="OnShareIntentionsToggled" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <VerticalStackLayout Spacing="8">
                                <Label x:Name="SocialMessagesHeaderLabel"
                                       Text="Messaggi"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextColor}" />
                                <VerticalStackLayout x:Name="SocialMessagesStack"
                                                     Spacing="10" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label x:Name="SocialTablesHeaderLabel"
                                       Text="I tuoi tavoli"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextColor}" />
                                <VerticalStackLayout x:Name="SocialTablesStack"
                                                     Spacing="10" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label x:Name="SocialInviteHeaderLabel"
                                       Text="Inviti tavolo"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextColor}" />
                                <VerticalStackLayout x:Name="SocialInviteStack"
                                                     Spacing="10" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label x:Name="SocialIncomingHeaderLabel"
                                       Text="Richieste in arrivo"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextColor}" />
                                <VerticalStackLayout x:Name="SocialIncomingStack"
                                                     Spacing="10" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label x:Name="SocialOutgoingHeaderLabel"
                                       Text="Richieste inviate"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextColor}" />
                                <VerticalStackLayout x:Name="SocialOutgoingStack"
                                                     Spacing="10" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label x:Name="SocialFriendsHeaderLabel"
                                       Text="Amici"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextColor}" />
                                <VerticalStackLayout x:Name="SocialFriendsStack"
                                                     Spacing="10" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="TableOverlay"
              IsVisible="False"
              InputTransparent="False">
            <BoxView BackgroundColor="#260F172A">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTableOverlayBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border x:Name="TableSheet"
                    Margin="16,0,16,96"
                    Padding="16"
                    VerticalOptions="End"
                    BackgroundColor="#FCFEFF"
                    Stroke="#DDE7F5"
                    StrokeThickness="1"
                    TranslationY="500">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1A0F172A" Offset="0,14" Radius="30" Opacity="0.18" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label x:Name="TableTitleLabel"
                                   Text="Tavolo"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextColor}" />
                            <Label x:Name="TableMetaLabel"
                                   Text="Venue"
                                   FontSize="12"
                                   TextColor="{StaticResource MutedTextColor}" />
                        </VerticalStackLayout>

                        <ImageButton Grid.Column="1"
                                     Source="icon-close-blue.svg"
                                     WidthRequest="34"
                                     HeightRequest="34"
                                     MinimumHeightRequest="34"
                                     Padding="9"
                                     Clicked="OnTableOverlayCloseClicked"
                                     BackgroundColor="#EEF2F7"
                                     BorderWidth="0"
                                     CornerRadius="17" />
                    </Grid>

                    <Label x:Name="TableStatusLabel"
                           Text=""
                           FontSize="12"
                           TextColor="{StaticResource PrimaryColorDark}"
                           IsVisible="False" />

                    <ActivityIndicator x:Name="TableLoadingIndicator"
                                       IsVisible="False"
                                       IsRunning="False"
                                       Color="{StaticResource PrimaryColor}" />

                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="TableRequestsHeaderLabel"
                               Text="Richieste"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}" />
                        <ScrollView MaximumHeightRequest="140">
                            <VerticalStackLayout x:Name="TableRequestsStack"
                                                 Spacing="10" />
                        </ScrollView>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Chat tavolo"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextColor}" />
                        <ScrollView MaximumHeightRequest="220">
                            <VerticalStackLayout x:Name="TableMessagesStack"
                                                 Spacing="10" />
                        </ScrollView>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <Border Padding="12,4"
                                BackgroundColor="#F8FBFF"
                                Stroke="#E3EBF5"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Entry x:Name="TableMessageEntry"
                                   Placeholder="Scrivi un messaggio"
                                   BackgroundColor="Transparent"
                                   TextColor="{StaticResource TextColor}"
                                   PlaceholderColor="{StaticResource MutedTextColor}" />
                        </Border>
                        <Button Grid.Column="1"
                                Text="Invia"
                                Clicked="OnSendTableMessageClicked"
                                MinimumHeightRequest="42"
                                Padding="12,10"
                                FontSize="13"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="EditProfileOverlay"
              IsVisible="False"
              InputTransparent="False">
            <BoxView BackgroundColor="#260F172A">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnEditProfileOverlayBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border x:Name="EditProfileSheet"
                    Margin="16,0,16,96"
                    Padding="16"
                    VerticalOptions="End"
                    BackgroundColor="#FCFEFF"
                    Stroke="#DDE7F5"
                    StrokeThickness="1"
                    TranslationY="500">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Modifica profilo"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextColor}" />
                            <Label x:Name="EditProfileHandleLabel"
                                   Text="@me"
                                   FontSize="12"
                                   TextColor="{StaticResource MutedTextColor}" />
                        </VerticalStackLayout>

                        <ImageButton Grid.Column="1"
                                     Source="icon-close-blue.svg"
                                     WidthRequest="34"
                                     HeightRequest="34"
                                     MinimumHeightRequest="34"
                                     Padding="9"
                                     Clicked="OnEditProfileOverlayCloseClicked"
                                     BackgroundColor="#EEF2F7"
                                     BorderWidth="0"
                                     CornerRadius="17" />
                    </Grid>

                    <ScrollView MaximumHeightRequest="420">
                        <VerticalStackLayout Spacing="10">
                            <Entry x:Name="EditDisplayNameEntry"
                                   Placeholder="Nome pubblico" />
                            <Entry x:Name="EditAvatarUrlEntry"
                                   Placeholder="Avatar URL" />
                            <Entry x:Name="EditBirthYearEntry"
                                   Placeholder="Anno di nascita"
                                   Keyboard="Numeric" />
                            <Picker x:Name="EditGenderPicker"
                                    Title="Genere" />
                            <Editor x:Name="EditBioEditor"
                                    Placeholder="Bio breve"
                                    AutoSize="TextChanges"
                                    MaxLength="280" />
                            <Editor x:Name="EditInterestsEditor"
                                    Placeholder="Interessi separati da virgola"
                                    AutoSize="TextChanges" />
                        </VerticalStackLayout>
                    </ScrollView>

                    <Label x:Name="EditProfileStatusLabel"
                           Text=""
                           FontSize="12"
                           TextColor="{StaticResource PrimaryColorDark}"
                           IsVisible="False" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8">
                        <Button Text="Annulla"
                                Clicked="OnEditProfileOverlayCloseClicked"
                                MinimumHeightRequest="42"
                                Padding="10,10"
                                FontSize="13"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Grid.Column="1"
                                Text="Salva"
                                Clicked="OnSaveProfileClicked"
                                MinimumHeightRequest="42"
                                Padding="10,10"
                                FontSize="13"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="DirectMessageOverlay"
              IsVisible="False"
              InputTransparent="False">
            <BoxView BackgroundColor="#260F172A">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDirectMessageOverlayBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border x:Name="DirectMessageSheet"
                    Margin="16,0,16,96"
                    Padding="16"
                    VerticalOptions="End"
                    BackgroundColor="#FCFEFF"
                    Stroke="#DDE7F5"
                    StrokeThickness="1"
                    TranslationY="500">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label x:Name="DirectMessageTitleLabel"
                                   Text="Chat"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextColor}" />
                            <Label x:Name="DirectMessageSubtitleLabel"
                                   Text="@user"
                                   FontSize="12"
                                   TextColor="{StaticResource MutedTextColor}" />
                        </VerticalStackLayout>

                        <ImageButton Grid.Column="1"
                                     Source="icon-close-blue.svg"
                                     WidthRequest="34"
                                     HeightRequest="34"
                                     MinimumHeightRequest="34"
                                     Padding="9"
                                     Clicked="OnDirectMessageOverlayCloseClicked"
                                     BackgroundColor="#EEF2F7"
                                     BorderWidth="0"
                                     CornerRadius="17" />
                    </Grid>

                    <Label x:Name="DirectMessageStatusLabel"
                           Text=""
                           FontSize="12"
                           TextColor="{StaticResource PrimaryColorDark}"
                           IsVisible="False" />

                    <ScrollView MaximumHeightRequest="320">
                        <VerticalStackLayout x:Name="DirectMessageMessagesStack"
                                             Spacing="10" />
                    </ScrollView>

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <Entry x:Name="DirectMessageEntry"
                               Placeholder="Scrivi un messaggio" />
                        <Button Grid.Column="1"
                                Text="Invia"
                                Clicked="OnSendDirectMessageClicked"
                                MinimumHeightRequest="42"
                                Padding="12,10"
                                FontSize="13"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Border Margin="16,0,16,18"
                Padding="14,12,14,8"
                VerticalOptions="End"
                BackgroundColor="#F7FBFF"
                Stroke="#DDE7F5"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#1A0F172A" Offset="0,14" Radius="28" Opacity="0.18" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8">
                <VerticalStackLayout Spacing="6"
                                     HorizontalOptions="Center">
                        <Border WidthRequest="54"
                            HeightRequest="54"
                            BackgroundColor="{StaticResource PrimaryColor}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="27" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#222563EB" Offset="0,10" Radius="22" Opacity="0.24" />
                        </Border.Shadow>
                        <Image Source="icon-map-white.svg"
                               WidthRequest="22"
                               HeightRequest="22"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Text="Mappa"
                           FontSize="11"
                           TextColor="{StaticResource TextColor}" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="6"
                                     HorizontalOptions="Center">
                    <ImageButton Source="icon-users-blue.svg"
                                 WidthRequest="54"
                                 HeightRequest="54"
                                 MinimumHeightRequest="54"
                                 Padding="15"
                                 Clicked="OnSocialClicked"
                                 BackgroundColor="#ECF2FF"
                                 BorderWidth="0"
                                 CornerRadius="27" />
                    <Label Text="Social"
                           FontSize="11"
                           TextColor="{StaticResource MutedTextColor}" />
                </VerticalStackLayout>

            </Grid>
        </Border>
    </Grid>
</ContentPage>
