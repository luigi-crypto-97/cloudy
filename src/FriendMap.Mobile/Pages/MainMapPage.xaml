<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FriendMap.Mobile.Pages.MainMapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    Title="Mappa">

    <Grid RowDefinitions="Auto,*">
        <Grid Padding="16,12" BackgroundColor="#FFFFFF">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout>
                    <Label Text="FriendMap" FontSize="24" FontAttributes="Bold" />
                    <Label Text="Mappa sociale della città" FontSize="13" TextColor="#64748B" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="Aggiorna" Clicked="OnRefreshClicked" />
            </Grid>
        </Grid>

        <Grid Grid.Row="1" BackgroundColor="#E8F1FB">
            <maps:Map x:Name="NativeMap"
                      IsShowingUser="True"
                      MapType="Street" />
            <AbsoluteLayout x:Name="BubbleLayer"
                            InputTransparent="False" />
        </Grid>
    </Grid>
</ContentPage>
