<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FriendMap.Mobile.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    ios:Page.UseSafeArea="True"
    BackgroundColor="#0B0F19"
    Title="Login">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="GlassEntryStyle" TargetType="Entry">
                <Setter Property="BackgroundColor" Value="#151B2B" />
                <Setter Property="TextColor" Value="#F1F5F9" />
                <Setter Property="PlaceholderColor" Value="#64748B" />
                <Setter Property="HeightRequest" Value="56" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!-- Background ambient glow -->
        <AbsoluteLayout>
            <Ellipse Fill="#7C3AED"
                     WidthRequest="400"
                     HeightRequest="400"
                     Opacity="0.18"
                     AbsoluteLayout.LayoutBounds="0.5,-0.1,400,400"
                     AbsoluteLayout.LayoutFlags="XProportional,YProportional" />
            <Ellipse Fill="#EC4899"
                     WidthRequest="300"
                     HeightRequest="300"
                     Opacity="0.12"
                     AbsoluteLayout.LayoutBounds="-0.1,0.9,300,300"
                     AbsoluteLayout.LayoutFlags="XProportional,YProportional" />
            <Ellipse Fill="#06B6D4"
                     WidthRequest="260"
                     HeightRequest="260"
                     Opacity="0.10"
                     AbsoluteLayout.LayoutBounds="1.1,0.5,260,260"
                     AbsoluteLayout.LayoutFlags="XProportional,YProportional" />
        </AbsoluteLayout>

        <ScrollView>
            <Grid Padding="28,24,28,36"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  RowSpacing="24">

                <!-- Hero -->
                <VerticalStackLayout Grid.Row="0"
                                     Spacing="12"
                                     Margin="0,32,0,0"
                                     Opacity="0"
                                     x:Name="HeroLayout">
                    <Border WidthRequest="80"
                            HeightRequest="80"
                            StrokeThickness="0"
                            Background="{StaticResource BrandGradient}"
                            HorizontalOptions="Start">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#8B5CF6" Offset="0,12" Radius="32" Opacity="0.5" />
                        </Border.Shadow>
                        <Label Text="⚡"
                               FontSize="40"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               TextColor="White" />
                    </Border>

                    <Label Text="cloudy"
                           FontSize="42"
                           FontAttributes="Bold"
                          
                           TextColor="White" />

                    <Label Text="Entra nella mappa live. Scopri chi c'è, scuoti e connettiti."
                           FontSize="{StaticResource FontSizeBody}"
                          
                           TextColor="#94A3B8"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>

                <!-- Form -->
                <VerticalStackLayout Grid.Row="1"
                                     Spacing="16"
                                     Opacity="0"
                                     x:Name="FormLayout">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Backend URL"
                               FontSize="{StaticResource FontSizeCaption}"
                               FontAttributes="Bold"
                              
                               TextColor="#CBD5E1" />
                        <Border Padding="16,0"
                                BackgroundColor="#151B2B"
                                Stroke="#2A3449"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Entry Placeholder="http://127.0.0.1:8080/"
                                   Text="{Binding ApiBaseUrl}"
                                   Keyboard="Url"
                                   IsEnabled="{Binding CanEditSettings}"
                                   Style="{StaticResource GlassEntryStyle}" />
                        </Border>
                        <Label Text="{Binding ConnectionHint}"
                               FontSize="{StaticResource FontSizeCaption}"
                              
                               TextColor="#64748B" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Nickname"
                               FontSize="{StaticResource FontSizeCaption}"
                               FontAttributes="Bold"
                              
                               TextColor="#CBD5E1" />
                        <Border Padding="16,0"
                                BackgroundColor="#151B2B"
                                Stroke="#2A3449"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Entry Placeholder="il tuo nickname"
                                   Text="{Binding Nickname}"
                                   IsEnabled="{Binding CanEditSettings}"
                                   Style="{StaticResource GlassEntryStyle}" />
                        </Border>
                    </VerticalStackLayout>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource BrandViolet}" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <Button Text="Verifica"
                                Command="{Binding VerifyBackendCommand}"
                                IsEnabled="{Binding CanEditSettings}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                BackgroundColor="#1E293B"
                                TextColor="#F1F5F9" />
                        <Button Grid.Column="1"
                                Text="Accedi"
                                Command="{Binding LoginCommand}"
                                IsEnabled="{Binding CanEditSettings}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Clicked="OnLoginClicked" />
                    </Grid>

                    <Border Padding="14"
                            BackgroundColor="#151B2B"
                            Stroke="#2A3449"
                            StrokeThickness="1"
                            IsVisible="{Binding HasBackendStatusMessage}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <Label Text="{Binding BackendStatusMessage}"
                               FontSize="{StaticResource FontSizeCaption}"
                              
                               TextColor="{Binding BackendStatusColor}" />
                    </Border>

                    <Border Padding="14"
                            BackgroundColor="#2A0A0A"
                            Stroke="#7F1D1D"
                            StrokeThickness="1"
                            IsVisible="{Binding HasError}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <Label Text="{Binding Error}"
                               FontSize="{StaticResource FontSizeCaption}"
                              
                               TextColor="#FCA5A5" />
                    </Border>
                </VerticalStackLayout>

                <!-- Footer badges -->
                <HorizontalStackLayout Grid.Row="2"
                                       Spacing="8"
                                       HorizontalOptions="Center"
                                       Opacity="0"
                                       x:Name="FooterLayout">
                    <Border Padding="10,6"
                            BackgroundColor="#151B2B"
                            Stroke="#2A3449"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="{Binding PushModeLabel}"
                               FontSize="{StaticResource FontSizeFootnote}"
                              
                               TextColor="#94A3B8" />
                    </Border>
                    <Border Padding="10,6"
                            BackgroundColor="#151B2B"
                            Stroke="#2A3449"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label Text="Dev login"
                               FontSize="{StaticResource FontSizeFootnote}"
                              
                               TextColor="#94A3B8" />
                    </Border>
                </HorizontalStackLayout>

                <!-- Hint -->
                <Label Grid.Row="3"
                       Text="Prima di accedere: su simulatore usa localhost, su iPhone usa l'IP del Mac visibile negli script dev."
                       FontSize="{StaticResource FontSizeFootnote}"
                      
                       TextColor="#475569"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"
                       Opacity="0"
                       x:Name="HintLabel" />
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
