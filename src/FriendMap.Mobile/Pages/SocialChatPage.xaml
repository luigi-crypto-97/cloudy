<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="FriendMap.Mobile.Pages.SocialChatPage"
             ios:Page.UseSafeArea="True"
             Shell.NavBarIsVisible="False"
             Title="Chat">

    <Grid RowDefinitions="Auto,*,Auto"
          BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#020617}">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              Padding="18,18,18,10"
              ColumnSpacing="12">
            <ImageButton Source="icon_back"
                         BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#111827}"
                         WidthRequest="42"
                         HeightRequest="42"
                         CornerRadius="21"
                         Clicked="OnBackClicked" />
            <VerticalStackLayout Grid.Column="1"
                                 Spacing="2"
                                 VerticalOptions="Center">
                <Label x:Name="TitleLabel"
                       Text="Chat"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                <Label x:Name="SubtitleLabel"
                       Text=""
                       FontSize="12"
                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
            </VerticalStackLayout>
            <ActivityIndicator Grid.Column="2"
                               x:Name="HeaderLoading"
                               IsVisible="False"
                               IsRunning="False"
                               Color="#4F46E5"
                               VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1"
                    x:Name="MessagesScroll"
                    Margin="16,0,16,12">
            <VerticalStackLayout x:Name="MessagesLayout"
                                 Spacing="10" />
        </ScrollView>

        <Grid Grid.Row="2"
              Padding="16,8,16,20"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="10">
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#111827}"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#1F2937}"
                    StrokeShape="RoundRectangle 22"
                    Padding="14,2">
                <Entry x:Name="MessageEntry"
                       Placeholder="Scrivi un messaggio..."
                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                       PlaceholderColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
                       HeightRequest="44"
                       ReturnType="Send"
                       Completed="OnSendClicked" />
            </Border>
            <Button Grid.Column="1"
                    Text="Invia"
                    Clicked="OnSendClicked"
                    BackgroundColor="#4F46E5"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="18"
                    HeightRequest="44"
                    Padding="18,0" />
        </Grid>
    </Grid>
</ContentPage>
