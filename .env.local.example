# Copy this file to .env.local and fill in the real values.
# .env.local is ignored by git and is loaded automatically by scripts/run-api.sh.

# Public/LAN API mode.
# Use Production when exposing the API through Caddy/public domain, so stack traces are not returned to the app.
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080

# Docker/Postgres production values.
POSTGRES_DB=friendmap
POSTGRES_USER=friendmap
POSTGRES_PASSWORD=<long-random-postgres-password>

# In produzione lascia questi bind su localhost e pubblica solo 80/443 via reverse proxy.
POSTGRES_BIND=127.0.0.1
REDIS_BIND=127.0.0.1
API_BIND=127.0.0.1
ADMIN_BIND=127.0.0.1

# S3-compatible bucket (server/R2/Supabase/MinIO). Aggiorna questi valori se cambi bucket.
MediaStorage__Provider=s3
MediaStorage__Bucket=cloudy-media
MediaStorage__Endpoint=https://<s3-endpoint>
MediaStorage__Region=<s3-region>
MediaStorage__AccessKeyId=<s3-access-key>
MediaStorage__SecretAccessKey=<s3-secret-key>
MediaStorage__PublicBaseUrl=
MediaStorage__ForcePathStyle=true
MediaStorage__UsePrivateBucket=true
MediaStorage__SignedUrlMinutes=15

# Sign in with Apple.
# Deve combaciare con il Bundle ID abilitato in Apple Developer > Identifiers.
AppleAuth__Audience=it.luiginegri.FriendMapSeed

# Protect /api/admin/* when the API is public. Use the same value for Admin app and API.
Admin__ApiKey=<long-random-admin-api-key>
Api__AdminApiKey=<long-random-admin-api-key>
Admin__Username=admin
Admin__Password=<long-random-admin-password>

# Demo/test data controls for feed/admin.
Cloudy__DemoSignals=false
Cloudy__TestUsersEnabled=false
