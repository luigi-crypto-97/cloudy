root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{swift,m,mm,c,h}]
indent_size = 4

[*.{md,json,yaml,yml,plist}]
indent_size = 2

[*.xcodeproj]
indent_size = tab

[{Gemfile,Rakefile,*.rb,.gitignore,.gitattributes}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2
